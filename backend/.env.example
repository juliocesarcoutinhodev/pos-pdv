# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/<DB_NAME>
SPRING_DATASOURCE_USERNAME=<USERNAME>
SPRING_DATASOURCE_PASSWORD=<PASSWORD>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

SPRING_FLYWAY_URL=jdbc:postgresql://<HOST>:5432/<DB_NAME>
SPRING_FLYWAY_USER=<USERNAME>
SPRING_FLYWAY_PASSWORD=<PASSWORD>

# Server
SERVER_PORT=8080

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info,prometheus

# Security
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=<YOUR_JWT_SECRET_MINIMUM_256_BITS_BASE64>
JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_ISSUER=pospdv
JWT_ACCESS_TOKEN_EXPIRATION=3600

# CNPJA Integration
CNPJA_API_URL=https://api.cnpja.com
CNPJA_API_TOKEN=<YOUR_CNPJA_API_TOKEN>

# Lookup Cache (CNPJ / ZIP)
LOOKUP_CACHE_ENABLED=true
LOOKUP_CACHE_CNPJ_SUCCESS_TTL_MINUTES=1440
LOOKUP_CACHE_CNPJ_NOT_FOUND_TTL_MINUTES=60
LOOKUP_CACHE_CNPJ_MAXIMUM_SIZE=50000
LOOKUP_CACHE_ZIP_SUCCESS_TTL_MINUTES=43200
LOOKUP_CACHE_ZIP_NOT_FOUND_TTL_MINUTES=60
LOOKUP_CACHE_ZIP_MAXIMUM_SIZE=50000

# MinIO (Image Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<YOUR_MINIO_SECRET_KEY>
MINIO_BUCKET=images
MINIO_AUTO_CREATE_BUCKET=true

# Customer reports company header (Jasper)
REPORT_COMPANY_LEGAL_NAME=
REPORT_COMPANY_TRADE_NAME=
REPORT_COMPANY_TAX_ID=
REPORT_COMPANY_PHONE=
REPORT_COMPANY_EMAIL=
REPORT_COMPANY_ADDRESS_LINE=

# Multipart upload
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# Profiles
SPRING_PROFILES_ACTIVE=local
