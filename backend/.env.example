# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/<DB_NAME>
SPRING_DATASOURCE_USERNAME=<USERNAME>
SPRING_DATASOURCE_PASSWORD=<PASSWORD>
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

SPRING_FLYWAY_URL=jdbc:postgresql://<HOST>:5432/<DB_NAME>
SPRING_FLYWAY_USER=<USERNAME>
SPRING_FLYWAY_PASSWORD=<PASSWORD>

# Server
SERVER_PORT=8080

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info,prometheus

# Security
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=<YOUR_JWT_SECRET_MINIMUM_256_BITS_BASE64>
JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_ISSUER=pospdv
JWT_ACCESS_TOKEN_EXPIRATION=3600

# Profiles
SPRING_PROFILES_ACTIVE=local
