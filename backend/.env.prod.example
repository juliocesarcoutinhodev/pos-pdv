# Copy this file to /opt/apps/pospdv-backend/.env on your VPS
# and fill with real values

# Spring
SPRING_PROFILES_ACTIVE=prod

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://vps7348.integrator.host:5432/pospdv
SPRING_DATASOURCE_USERNAME=<DB_USERNAME>
SPRING_DATASOURCE_PASSWORD=<DB_PASSWORD>

# Flyway
SPRING_FLYWAY_URL=jdbc:postgresql://vps7348.integrator.host:5432/pospdv
SPRING_FLYWAY_USER=<DB_USERNAME>
SPRING_FLYWAY_PASSWORD=<DB_PASSWORD>

# Server
SERVER_PORT=8080

# Actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info

# Security
APP_CORS_ALLOWED_ORIGINS=https://seu-dominio.com,https://app.seu-dominio.com
JWT_SECRET=<YOUR_JWT_SECRET_MINIMUM_256_BITS_BASE64>
JWT_ISSUER=pospdv
JWT_ACCESS_TOKEN_EXPIRATION=900

# CNPJA Integration
CNPJA_API_URL=https://api.cnpja.com
CNPJA_API_TOKEN=<YOUR_CNPJA_API_TOKEN>

# Lookup Cache (CNPJ / ZIP)
LOOKUP_CACHE_ENABLED=true
LOOKUP_CACHE_CNPJ_SUCCESS_TTL_MINUTES=1440
LOOKUP_CACHE_CNPJ_NOT_FOUND_TTL_MINUTES=60
LOOKUP_CACHE_CNPJ_MAXIMUM_SIZE=50000
LOOKUP_CACHE_ZIP_SUCCESS_TTL_MINUTES=43200
LOOKUP_CACHE_ZIP_NOT_FOUND_TTL_MINUTES=60
LOOKUP_CACHE_ZIP_MAXIMUM_SIZE=50000
