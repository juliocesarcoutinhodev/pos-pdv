    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"name\": \"{{name}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new user account."
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate regular user. Stores access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set(\"access_token\", body.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate the default admin user before testing roles and user management."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Admin login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set(\"access_token\", body.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Refresh access token using refresh token cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Refresh successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set(\"access_token\", body.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Revoke refresh tokens and clear refresh cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Logout successful\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Current User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "me"]
            },
            "description": "Get current authenticated user info including role names."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin (requires ADMIN role)",
      "item": [
        {
          "name": "Admin Ping",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/ping",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "ping"]
            },
            "description": "Admin-only endpoint. Returns 403 without ADMIN role."
          },
          "response": []
        },
        {
          "name": "Admin Only",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin-only",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin-only"]
            },
            "description": "Admin-only endpoint via @PreAuthorize."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Role Management (requires ADMIN role)",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/roles?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "List roles and capture USER/ADMIN ids for the rest of the collection."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"List roles successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var body = pm.response.json();",
                  "    var roles = body.content || [];",
                  "    var userRole = roles.find(function (r) { return r.name === 'USER'; });",
                  "    var adminRole = roles.find(function (r) { return r.name === 'ADMIN'; });",
                  "    if (userRole) pm.collectionVariables.set('user_role_id', userRole.id);",
                  "    if (adminRole) pm.collectionVariables.set('admin_role_id', adminRole.id);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MANAGER\",\n  \"description\": \"Gerente da operação\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/roles",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles"]
            },
            "description": "Create a custom role and store its id in {{role_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create role successful\", function () {",
                  "    pm.response.to.have.status(201);",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set(\"role_id\", body.id);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Role By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles", "{{role_id}}"]
            },
            "description": "Fetch role details by id."
          },
          "response": []
        },
        {
          "name": "Update Role (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MANAGER\",\n  \"description\": \"Gerente com acesso total à operação\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles", "{{role_id}}"]
            },
            "description": "Full update for role."
          },
          "response": []
        },
        {
          "name": "Update Role (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Gerente atualizado via patch\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles", "{{role_id}}"]
            },
            "description": "Partial update for role."
          },
          "response": []
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles", "{{role_id}}"]
            },
            "description": "Delete a custom role created in this collection. System roles and roles assigned to users return 409 Conflict."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management (requires ADMIN role)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "name",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "email",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "active",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "List users with optional filters and pagination."
          },
          "response": []
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"name\": \"New User\",\n  \"password\": \"password123\",\n  \"roleIds\": [\"{{user_role_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Create a user with USER role. Run List Roles first to populate {{user_role_id}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create user successful\", function () {",
                  "    pm.response.to.have.status(201);",
                  "    var body = pm.response.json();",
                  "    pm.collectionVariables.set(\"user_id\", body.id);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Get user details by id."
          },
          "response": []
        },
        {
          "name": "Update User (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated@example.com\",\n  \"name\": \"Updated User\",\n  \"password\": \"newpassword123\",\n  \"roleIds\": [\"{{user_role_id}}\", \"{{admin_role_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Full update user. This example promotes the user to USER + ADMIN."
          },
          "response": []
        },
        {
          "name": "Update User (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Patched User\",\n  \"roleIds\": [\"{{user_role_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Partial update user. This example leaves only USER role."
          },
          "response": []
        },
        {
          "name": "Reactivate User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Reactivate a previously deactivated user."
          },
          "response": []
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "{{user_id}}"]
            },
            "description": "Deactivate user (soft delete)."
          },
          "response": []
        }
      ]
    }
  ]
}
