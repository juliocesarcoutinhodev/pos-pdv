    },
    {
      "key": "name",
      "value": "Test User",
      "type": "string"
    },
    {
      "key": "password",
      "value": "password123",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@email.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "admin123",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
