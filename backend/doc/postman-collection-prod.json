{
  "info": {
    "name": "POS PDV - Production",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Production collection. Base URL: https://vps7348.integrator.host/pospdv"
  },
  "variable": [
