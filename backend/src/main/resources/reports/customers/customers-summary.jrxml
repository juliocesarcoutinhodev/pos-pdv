			<expression><![CDATA[$P{ACTIVE_FILTER} == null ? "Todos" : ($P{ACTIVE_FILTER} ? "Apenas ativos" : "Apenas inativos")]]></expression>
		</element>
		<element kind="textField" uuid="73577b60-a7c7-469d-8439-4473f7b2610c" x="620" y="0" width="70" height="14" style="FilterLabel">
