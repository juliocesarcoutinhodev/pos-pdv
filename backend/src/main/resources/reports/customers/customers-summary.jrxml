		</element>
		<element kind="textField" uuid="dacdd74f-26a4-485b-b58a-395c7ce41322" x="690" y="0" width="112" height="14" hTextAlign="Right" style="FilterValue">
			<expression><![CDATA[$P{BIRTH_MONTH} == null ? "Todos" : String.valueOf($P{BIRTH_MONTH})]]></expression>
		</element>
		<element kind="textField" uuid="8279e8d2-b93f-4bd9-82b5-cb21777c1830" x="0" y="20" width="84" height="14" style="FilterLabel">
			<expression><![CDATA[
($P{BIRTH_DATE_FROM} == null && $P{BIRTH_DATE_TO} == null) ? "" : "Nascimento:"
            ]]></expression>
		</element>
		<element kind="textField" uuid="ea72c552-62f0-4a18-84d1-309596a7c503" x="84" y="20" width="430" height="14" style="FilterValue">
			<expression><![CDATA[
($P{BIRTH_DATE_FROM} == null && $P{BIRTH_DATE_TO} == null)
? ""
: (
($P{BIRTH_DATE_FROM} == null ? "sem inicio" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{BIRTH_DATE_FROM}))
+ " ate " +
($P{BIRTH_DATE_TO} == null ? "sem fim" : new java.text.SimpleDateFormat("dd/MM/yyyy").format($P{BIRTH_DATE_TO}))
)
            ]]></expression>
		</element>
