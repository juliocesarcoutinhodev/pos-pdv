			<expression><![CDATA[$P{NAME_FILTER} == null || $P{NAME_FILTER}.trim().isEmpty() ? "Todos" : $P{NAME_FILTER}]]></expression>
		</element>
		<element kind="textField" uuid="52f7c84c-a7c5-4573-8cb2-17c4e76a2610" x="346" y="0" width="84" height="14" style="FilterLabel">
