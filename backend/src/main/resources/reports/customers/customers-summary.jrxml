<jasperReport name="CustomersSummary" language="java" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="50a10fe9-c0c5-4092-b815-e8df0b00ca46">
