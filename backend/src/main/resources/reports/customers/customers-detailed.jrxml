	<parameter name="COMPANY_ADDRESS" class="java.lang.String"/>
	<parameter name="NAME_FILTER" class="java.lang.String"/>
	<parameter name="ACTIVE_FILTER" class="java.lang.Boolean"/>
	<parameter name="BIRTH_MONTH" class="java.lang.Integer"/>
	<parameter name="BIRTH_DATE_FROM" class="java.sql.Date"/>
	<parameter name="BIRTH_DATE_TO" class="java.sql.Date"/>
	<parameter name="PRINTED_AT" forPrompting="false" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[
SELECT
    c.id::text AS id,
    c.name AS name,
    c.tax_id AS tax_id,
    c.ie_or_rg AS ie_or_rg,
    c.gender AS gender,
    c.birth_date AS birth_date,
    c.email AS email,
    c.phone AS phone,
    c.image_id AS image_id,
    a.zip_code AS zip_code,
    a.street AS street,
    a.number AS number,
    a.complement AS complement,
    a.district AS district,
    a.city AS city,
    a.state AS state,
    c.created_at AS created_at,
    c.updated_at AS updated_at,
    CASE WHEN c.deleted_at IS NULL THEN 'Ativo' ELSE 'Inativo' END AS status
FROM tb_customers c
LEFT JOIN tb_addresses a ON a.id = c.address_id
WHERE
    ($P{NAME_FILTER} IS NULL OR TRIM($P{NAME_FILTER}) = '' OR c.name ILIKE '%' || $P{NAME_FILTER} || '%')
    AND ($P{ACTIVE_FILTER} IS NULL OR (c.deleted_at IS NULL) = $P{ACTIVE_FILTER})
    AND ($P{BIRTH_MONTH} IS NULL OR EXTRACT(MONTH FROM c.birth_date)::int = $P{BIRTH_MONTH})
    AND ($P{BIRTH_DATE_FROM} IS NULL OR c.birth_date >= $P{BIRTH_DATE_FROM})
    AND ($P{BIRTH_DATE_TO} IS NULL OR c.birth_date <= $P{BIRTH_DATE_TO})
ORDER BY c.name
    ]]></query>
	<field name="id" class="java.lang.String"/>
	<field name="name" class="java.lang.String"/>
	<field name="tax_id" class="java.lang.String"/>
	<field name="ie_or_rg" class="java.lang.String"/>
	<field name="gender" class="java.lang.String"/>
	<field name="birth_date" class="java.sql.Date"/>
	<field name="email" class="java.lang.String"/>
